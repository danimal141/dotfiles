# Vim plugin caches (vim-plug が動的に管理する third-party plugin)
vim/.vim/plugged/*
vim/.vim/.netrwhist
vim/.vim/sessions/*

# Claude local work directories (only the ones that may appear at repo root)
/.claude/*
.claude/work/
.claude/tmp/
.claude/settings.local.json

# Codex local report output
.codex/reports/

# VSCode settings backup
tools/vscode/settings.bak.json

# Node modules (pre-commit + secretlint)
node_modules/

# pre-commit cache
.pre-commit-cache/

# Local debug dumps (e.g. `defaults read` outputs)
.tmp-*.txt

# `nix build` / `nix run` の derivation output symlink
result
result-*

# APM dependencies
apm_modules/
tools/apm/.claude/

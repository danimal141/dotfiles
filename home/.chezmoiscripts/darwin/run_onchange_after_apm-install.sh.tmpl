#!/usr/bin/env bash
# Triggered by `chezmoi apply` after dot_apm/apm.yml has been placed.
# Re-runs whenever apm.yml content changes so installed skills stay in sync.
#
# apm.yml hash: {{ include "dot_apm/apm.yml" | sha256sum }}

set -euo pipefail

if ! command -v apm >/dev/null 2>&1; then
  echo "apm not installed; skipping"
  exit 0
fi

cd "${HOME}/.apm"
apm install

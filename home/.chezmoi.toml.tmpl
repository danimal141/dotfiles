{{- /* Initial chezmoi config, evaluated by `chezmoi init` */ -}}

{{- $machineType := "" -}}

{{- /* Auto-detect ephemeral environments (CI, devcontainer, root user) */ -}}
{{- if or (env "CODESPACES") (env "REMOTE_CONTAINERS") (eq .chezmoi.username "root") -}}
{{-   $machineType = "ephemeral" -}}
{{- /* Auto-detect work hosts: "work-*" prefix or specific company-issued hostnames */ -}}
{{- else if or (hasPrefix .chezmoi.hostname "work-") (eq .chezmoi.hostname "hideaki-ishii1") -}}
{{-   $machineType = "work" -}}
{{- end -}}

{{- $name := promptStringOnce . "name" "Full name (e.g. Hideaki Ishii)" -}}
{{- $email := promptStringOnce . "email" "Primary email" -}}
{{- if eq $machineType "" -}}
{{-   $machineType = promptStringOnce . "machineType" "Machine type (work / personal / ephemeral)" "personal" -}}
{{- end -}}

[data]
    name = {{ $name | quote }}
    email = {{ $email | quote }}
    machineType = {{ $machineType | quote }}

[edit]
    apply = true

[diff]
    pager = "less -R"

{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/herdr-agent-state.sh\" session",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "clear|logout|other",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$HOME/.claude/hooks/session-namer.py\"",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "gog@gog-skills": true,
    "gws@gws-skills": true,
    "typescript-lsp@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "ruby-lsp@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "gws-skills": {
      "source": {
        "source": "directory",
        "path": "/Library/Application Support/ClaudeCode/marketplace/gws-skills"
      }
    },
    "gog-skills": {
      "source": {
        "source": "directory",
        "path": "/Library/Application Support/ClaudeCode/marketplace/gog-skills"
      }
    }
  },
  "model": "opus"
}

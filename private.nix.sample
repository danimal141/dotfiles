# cp private.nix.sample private.nix && $EDITOR private.nix
#
# 既存の macOS アカウント名 (`whoami` の結果と一致) を username に書く。
# system.primaryUser / home.homeDirectory = "/Users/${username}" に使う値で、
# 新規アカウント作成ではない。`whoami` と異なる名前を入れると
# home-manager の activation が /Users/<実在しない名前> を見に行って失敗する。
#
# private.nix は .gitignore 対象。各マシンにローカル配置のみ。
{
  username = "your-username";
  gitName  = "Your Name";
  gitEmail = "you@example.com";
}

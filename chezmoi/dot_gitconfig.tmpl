[user]
	name = {{ .name }}
	email = {{ .email }}
[core]
	excludesfile = ~/.gitignore
	editor = nvim
[diff]
	ignoreSubmodules = dirty

# 業務 repo (~/Documents/dev/work/ 配下) では別 ID を使う。
# ~/.gitconfig.work は chezmoi / git どちらでも追跡しない手書きファイル
# (= public repo に業務メールを焼かない意図)。中身は [user] name / email を
# 各 work Mac でローカルに書く。詳細は README の「業務 repo の git identity 分離」。
[includeIf "gitdir:~/Documents/dev/work/"]
	path = ~/.gitconfig.work

{{- /*
  chezmoi 初期 config の生成テンプレート (`chezmoi init` 時に評価される)。

  PC ごとに値が変わる項目 (username / email / 環境別の AWS_PROFILE / IDE 設定
  等) を一本の dotfile に押し込めるため、chezmoi の data + tmpl で吸収する。

  data 値 (machineType) は 3 段階で決める:
    1. 「ephemeral」(CI / devcontainer / root) を最優先で自動判定する。
       これらの環境では work / personal の質問を出してはならない (CI 詰まる)。
    2. それ以外は hostname 規約 (work / personal*) で自動判定する。
       nix-darwin が `networking.hostName` を強制するため、IT 部門が割り当てた
       個別 hostname に依存せず確実に分類できる。
    3. どちらでも分類できないときだけ `promptStringOnce` で対話入力する。
       `promptStringOnce` を使う理由は、二度目以降の `chezmoi init` で値を
       保持して再質問しないため (CI で chezmoi init を流すケースに有用)。

  `[edit] apply = true` を有効にしているため `chezmoi edit` で保存した瞬間に
  ~/ に反映される。reedit ループは回避できるが、テンプレ syntax error が
  即座に ~/.zshrc を破壊するリスクがある (README に運用注意を明記)。
*/ -}}

{{- $machineType := "" -}}

{{- /* CI / devcontainer / root はマシン分類できない & 不要なので ephemeral 固定 */ -}}
{{- if or (env "CODESPACES") (env "REMOTE_CONTAINERS") (eq .chezmoi.username "root") -}}
{{-   $machineType = "ephemeral" -}}
{{- /* hostname 規約: 仕事用は "work"、個人用は "personal" / "personal2" / ...
       nix-darwin の networking.hostName で固定するので IT 払い出しの hostname に左右されない */ -}}
{{- else if eq .chezmoi.hostname "work" -}}
{{-   $machineType = "work" -}}
{{- else if hasPrefix .chezmoi.hostname "personal" -}}
{{-   $machineType = "personal" -}}
{{- end -}}

{{- /* name / email は public repo に晒さない方針:
        どの machineType でも `promptStringOnce` で初回だけ対話入力させ、以降は
        ~/.config/chezmoi/chezmoi.toml に cache される。`[user]` ブロックには
        この値が入るが、業務 commit 用 ID (= 仕事ドメインのアドレス) は
        ~/.gitconfig.work に手書きで分離して `includeIf` 経路で上書きする
        (chezmoi/dot_gitconfig.tmpl 参照)。 */ -}}
{{- $name := promptStringOnce . "name" "Full name (e.g. Hideaki Ishii)" -}}
{{- $email := promptStringOnce . "email" "Primary email" -}}
{{- if eq $machineType "" -}}
{{-   $machineType = promptStringOnce . "machineType" "Machine type (work / personal / ephemeral)" "personal" -}}
{{- end -}}

# `sourceDir` は `chezmoi init --source <path>` 実行時の引数を chezmoi が
# 組み込み変数 `.chezmoi.sourceDir` として解決した値で固定する。これがないと
# 引数なしで `chezmoi init` を再実行したときデフォルト ~/.local/share/chezmoi
# にフォールバックしてリポジトリを見失う。
sourceDir = {{ .chezmoi.sourceDir | quote }}

[data]
    name = {{ $name | quote }}
    email = {{ $email | quote }}
    machineType = {{ $machineType | quote }}

[edit]
    apply = true

[diff]
    pager = "less -R"
